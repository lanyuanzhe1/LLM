              },
              "storage_type": {
                "anyOf": [
                  {
                    "maxLength": 128,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Storage Type"
              },
              "moisture_percent": {
                "anyOf": [
                  {
                    "maximum": 100,
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Moisture Percent"
              },
              "grain_temperature_c": {
                "anyOf": [
                  {
                    "maximum": 100,
                    "minimum": -50,
