              },
              "goal": {
                "anyOf": [
                  {
                    "maxLength": 1000,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Goal"
              }
            },
            "title": "CaseData",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "properties": {
          "request_id": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Request Id",
            "type": "string"
          },
