                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Grain Temperature C"
              },
              "temperature_trend": {
                "anyOf": [
                  {
                    "enum": [
                      "rising",
                      "stable",
                      "falling"
                    ],
                    "type": "string"
