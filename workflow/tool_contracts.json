{
  "name": "粮储智研助手技术实体_v1",
  "start_parameters": [
    "AGENT_USER_INPUT",
    "REQUEST_ID",
    "SESSION_ID",
    "USER_ROLE",
    "TASK_TYPE",
    "CASE_JSON"
  ],
  "authentication": {
    "header": "Authorization",
    "value": "Bearer ${TOOLS_SERVICE_TOKEN}"
  },
  "tools": [
    {
      "name": "grain_retrieve",
      "method": "POST",
      "path": "/tools/v1/retrieve",
      "request_fields": [
        "request_id",
        "query",
        "top_k",
        "filters"
      ],
      "response_fields": [
        "request_id",
        "query",
        "evidences",
        "quality"
      ],
      "request_schema": {
        "$defs": {
          "RetrievalFilters": {
            "additionalProperties": false,
            "properties": {
              "source_type": {
                "anyOf": [
                  {
                    "maxLength": 128,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Source Type"
              },
              "authority_level": {
                "anyOf": [
                  {
                    "maxLength": 128,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Authority Level"
              }
            },
            "title": "RetrievalFilters",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "properties": {
          "request_id": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Request Id",
            "type": "string"
          },
          "query": {
            "maxLength": 8000,
            "minLength": 1,
            "title": "Query",
            "type": "string"
          },
          "top_k": {
            "default": 5,
            "maximum": 20,
            "minimum": 1,
            "title": "Top K",
            "type": "integer"
          },
          "filters": {
            "$ref": "#/$defs/RetrievalFilters"
          }
        },
        "required": [
          "request_id",
          "query"
        ],
        "title": "RetrieveRequest",
        "type": "object"
      },
      "response_schema": {
        "$defs": {
          "Evidence": {
            "additionalProperties": false,
            "properties": {
              "evidence_id": {
                "maxLength": 128,
                "minLength": 1,
                "title": "Evidence Id",
                "type": "string"
              },
              "document_id": {
                "maxLength": 128,
                "minLength": 1,
                "title": "Document Id",
                "type": "string"
              },
              "title": {
                "maxLength": 512,
                "minLength": 1,
                "title": "Title",
                "type": "string"
              },
              "source": {
                "maxLength": 1024,
                "minLength": 1,
                "title": "Source",
                "type": "string"
              },
              "page": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Page"
              },
              "section": {
                "anyOf": [
                  {
                    "maxLength": 256,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Section"
              },
              "article_no": {
                "anyOf": [
                  {
                    "maxLength": 256,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Article No"
              },
              "text": {
                "maxLength": 32000,
                "minLength": 1,
                "title": "Text",
                "type": "string"
              },
              "score": {
                "anyOf": [
                  {
                    "maximum": 1.0,
                    "minimum": -1.0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Score"
              },
              "authority_level": {
                "default": "unknown",
                "maxLength": 256,
                "minLength": 1,
                "title": "Authority Level",
                "type": "string"
              },
              "version": {
                "anyOf": [
                  {
                    "maxLength": 256,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Version"
              },
              "quality_flags": {
                "items": {
                  "maxLength": 128,
                  "minLength": 1,
                  "type": "string"
                },
                "maxItems": 20,
                "title": "Quality Flags",
                "type": "array"
              }
            },
            "required": [
              "evidence_id",
              "document_id",
              "title",
              "source",
              "text",
              "score"
            ],
            "title": "Evidence",
            "type": "object"
          },
          "RetrievalQuality": {
            "properties": {
              "top_score": {
                "maximum": 1.0,
                "minimum": -1.0,
                "title": "Top Score",
                "type": "number"
              },
              "sufficient": {
                "title": "Sufficient",
                "type": "boolean"
              }
            },
            "required": [
              "top_score",
              "sufficient"
            ],
            "title": "RetrievalQuality",
            "type": "object"
          }
        },
        "properties": {
          "request_id": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Request Id",
            "type": "string"
          },
          "query": {
            "maxLength": 8000,
            "minLength": 1,
            "title": "Query",
            "type": "string"
          },
          "evidences": {
            "items": {
              "$ref": "#/$defs/Evidence"
            },
            "maxItems": 20,
            "title": "Evidences",
            "type": "array"
          },
          "quality": {
            "$ref": "#/$defs/RetrievalQuality"
          }
        },
        "required": [
          "request_id",
          "query",
          "evidences",
          "quality"
        ],
        "title": "RetrieveResponse",
        "type": "object"
      }
    },
