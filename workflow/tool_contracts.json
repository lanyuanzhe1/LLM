    {
      "name": "grain_case_evaluate",
      "method": "POST",
      "path": "/tools/v1/cases/evaluate",
      "request_fields": [
        "request_id",
        "case"
      ],
      "response_fields": [
        "request_id",
        "needs_input",
        "missing_fields",
        "question",
        "rules"
      ],
      "request_schema": {
        "$defs": {
          "CaseData": {
            "additionalProperties": false,
            "properties": {
              "grain_type": {
                "anyOf": [
                  {
                    "maxLength": 128,
                    "minLength": 1,
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
