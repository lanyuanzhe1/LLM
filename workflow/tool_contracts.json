            "maxItems": 20,
            "title": "Rules",
            "type": "array"
          }
        },
        "required": [
          "request_id",
          "needs_input",
          "missing_fields"
        ],
        "title": "CaseEvaluateResponse",
        "type": "object"
      }
    },
